{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "mocha",
  "plugins": ["@stryker-mutator/mocha-runner"],
  "coverageAnalysis": "perTest",
  "checkers": [],
  "mutate": [
    "lib/unicodeRange.js",
    "lib/unquote.js",
    "lib/escapeJsStringLiteral.js",
    "lib/stripLocalTokens.js",
    "lib/codepointMaps.js",
    "lib/normalizeFontPropertyValue.js",
    "lib/injectSubsetDefinitions.js",
    "lib/parseFontVariationSettings.js",
    "lib/extractReferencedCustomPropertyNames.js",
    "lib/fontFaceHelpers.js",
    "lib/fontFeatureHelpers.js",
    "lib/getCssRulesByProperty.js",
    "lib/findCustomPropertyDefinitions.js",
    "lib/variationAxes.js",
    "lib/parseCommandLineOptions.js",
    "lib/concurrencyLimit.js",
    "lib/promiseWeakCache.js",
    "lib/wasmQueue.js",
    "lib/sfntCache.js",
    "lib/progress.js",
    "lib/piscinaRunWithTimeout.js",
    "lib/collectFeatureGlyphIds.js",
    "lib/gatherStylesheetsWithPredicates.js",
    "lib/getFontInfo.js",
    "lib/warnAboutMissingGlyphs.js",
    "lib/extractVisibleText.js",
    "lib/subsetFontWithGlyphs.js",
    "lib/fontConverter.js"
  ],
  "mochaOptions": {
    "spec": [
      "test/unicodeRange.js",
      "test/unquote.js",
      "test/escapeJsStringLiteral.js",
      "test/stripLocalTokens.js",
      "test/codepointMaps.js",
      "test/normalizeFontPropertyValue.js",
      "test/injectSubsetDefinitions.js",
      "test/parseFontVariationSettings.js",
      "test/extractReferencedCustomPropertyNames.js",
      "test/fontFaceHelpers.js",
      "test/fontFeatureHelpers.js",
      "test/getCssRulesByProperty.js",
      "test/findCustomPropertyDefinitions.js",
      "test/variationAxes.js",
      "test/parseCommandLineOptions.js",
      "test/concurrencyLimit.js",
      "test/promiseWeakCache.js",
      "test/wasmQueue.js",
      "test/sfntCache.js",
      "test/progress.js",
      "test/piscinaRunWithTimeout.js",
      "test/collectFeatureGlyphIds.js",
      "test/gatherStylesheetsWithPredicates.js",
      "test/getFontInfo.js",
      "test/warnAboutMissingGlyphs.js",
      "test/extractVisibleText.js",
      "test/subsetFontWithGlyphs.js",
      "test/fontConverter.js",
      "test/featureTagExtraction.js",
      "test/fontVariantGsub.js"
    ]
  },
  "timeoutMS": 10000,
  "concurrency": 3,
  "reporters": ["clear-text", "progress", "json"],
  "clearTextReporter": {
    "allowColor": false,
    "reportTests": false
  },
  "ignoreStatic": true
}
